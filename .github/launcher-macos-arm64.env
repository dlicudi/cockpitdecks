COCKPITDECKS_XP_REF=v5.5.2-beta.2

COCKPITDECKS_LD_REPOSITORY=dlicudi/cockpitdecks_ld
COCKPITDECKS_LD_REF=v1.2.2

COCKPITDECKS_SD_REPOSITORY=dlicudi/cockpitdecks_sd
COCKPITDECKS_SD_REF=v1.1.6

COCKPITDECKS_WM_REPOSITORY=dlicudi/cockpitdecks_wm
COCKPITDECKS_WM_REF=v2.3.1

COCKPITDECKS_EXT_REPOSITORY=dlicudi/cockpitdecks_ext
# No semantic-version tag is available in this repo yet.
COCKPITDECKS_EXT_REF=stack-2026-03-22-xp124

COCKPITDECKS_BX_REPOSITORY=dlicudi/cockpitdecks_bx
COCKPITDECKS_BX_REF=v1.2.7

XPLANE_WEBAPI_REPOSITORY=dlicudi/xplane-webapi
