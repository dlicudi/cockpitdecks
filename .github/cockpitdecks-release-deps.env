# Reproducible dependency refs for the launcher release.
# Update this file in the same commit that prepares a new launcher release.
# cockpitdecks_xp, cockpitdecks_ld, cockpitdecks_sd, cockpitdecks_wm,
# cockpitdecks_ext, cockpitdecks_bx, and cockpitdecks_xpwebapi are now
# packages inside the cockpitdecks monorepo and are no longer checked out separately.

PYTHON_LOUPEDECK_LIVE_REPOSITORY=dlicudi/python-loupedeck-live
PYTHON_LOUPEDECK_LIVE_REF=v1.5.1

PYTHON_ELGATO_STREAMDECK_REPOSITORY=dlicudi/python-elgato-streamdeck
PYTHON_ELGATO_STREAMDECK_REF=master
