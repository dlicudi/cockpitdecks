<!DOCTYPE html>
<html>
<head>
    <title>Cockpitdecks - {{ deck.name }} </title>
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover, user-scalable=no">
<style type="text/css">
/* dark grey on light blue */
:root {
    --font-color: #424242;
    --bg-color: #A8B7E6;
    --background-color: #DDDDDD;
    --deck-background-color: #DDDDDD;
    --panel-color: rgba(22, 28, 36, 0.72);
    --panel-border: rgba(255, 255, 255, 0.16);
}
/* light orange on dark grey */
[data-theme="dark"] {
    --font-color: #FECC66;
    --bg-color: #333333;
}

html,
body {
    width: 100%;
    height: 100%;
    margin: 0;
    padding: 0;
    font-family: sans-serif;
    background-color: var(--background-color);
    overflow: hidden;
}

body {
  color: var(--font-color);
  overscroll-behavior: none;
  touch-action: manipulation;
}

#app {
  position: relative;
  width: 100vw;
  width: 100dvw;
  height: 100vh;
  height: 100dvh;
  padding:
    max(12px, env(safe-area-inset-top))
    max(12px, env(safe-area-inset-right))
    max(12px, env(safe-area-inset-bottom))
    max(12px, env(safe-area-inset-left));
  box-sizing: border-box;
  background:
    radial-gradient(circle at top, rgba(255,255,255,0.2), transparent 45%),
    linear-gradient(180deg, rgba(11, 18, 32, 0.08), rgba(11, 18, 32, 0.22));
}

#deck-shell {
  position: relative;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

#deck {
  position: absolute;
  top: 0;
  left: 0;
  transform-origin: top left;
  will-change: transform;
  display: block;
}

#buttonWrapper {
  position: absolute;
  top: 16px;
  right: 16px;
  display: flex;
  gap: 8px;
  padding: 8px;
  border-radius: 14px;
  background: var(--panel-color);
  border: 1px solid var(--panel-border);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  z-index: 10;
}

input[type="button"] {
  padding: 0;
  width: 36px;
  height: 36px;
  border: 1px solid var(--bg-color);
  margin: 0;
  border-radius: 10px;
  color: var(--font-color);
  background-color: var(--bg-color);
  font-size: 18px;
  line-height: 1;
}
</style>
</head>
<body>
<div id="app">
    <div id="deck-shell">
        <canvas id="deck"></canvas>
    </div>
</div>

<script src="/assets/js/deck.js" type="text/javascript"></script>
<script type="text/javascript">
//
// Deck config (injected by Cockpitdecks Flask server)
//
const DECK = {{ deck|tojson(indent=2) }};

const DEFAULT_BACKGROUND_COLOR_ALT = "#333333"

const DECK_TYPE_KEY = 'deck-type-flat';

const DEBUG = (DECK[DECK_TYPE_KEY].debug != undefined) ? DECK[DECK_TYPE_KEY].debug : false;
const ZOOM  = (DECK[DECK_TYPE_KEY].zoom  != undefined) ? DECK[DECK_TYPE_KEY].zoom  : true;
const DARK  = (DECK[DECK_TYPE_KEY].background?.alt_color != undefined);

const BACKGROUND_COLOR_ALT = DECK[DECK_TYPE_KEY].background?.alt_color || DEFAULT_BACKGROUND_COLOR_ALT;

//
// Canvas + LiveDeck setup
//
const DECK_SHELL_ELEM = document.getElementById('deck-shell');
const canvas          = document.getElementById('deck');

let deck_base_width  = 0;
let deck_base_height = 0;
let zoom_factor      = 1;

function apply_viewport_layout() {
    if (deck_base_width <= 0 || deck_base_height <= 0) return;
    const shell_w = DECK_SHELL_ELEM.clientWidth  || window.innerWidth;
    const shell_h = DECK_SHELL_ELEM.clientHeight || window.innerHeight;
    const fit     = Math.min(shell_w / deck_base_width, shell_h / deck_base_height);
    const scale   = Math.max(0.1, fit * zoom_factor);
    const x = Math.max(0, (shell_w - deck_base_width  * scale) / 2);
    const y = Math.max(0, (shell_h - deck_base_height * scale) / 2);
    canvas.style.transform = `translate(${x}px, ${y}px) scale(${scale})`;
}

window.cockpitdecksSetDeckSize = function(w, h) {
    deck_base_width  = w;
    deck_base_height = h;
    apply_viewport_layout();
};

const deck = new LiveDeck(canvas, DECK);

//
// Zoom controls
//
const btns_elem = document.createElement("div");
btns_elem.setAttribute("id", "buttonWrapper");
btns_elem.setAttribute("data-theme", "light");

if (ZOOM) {
    const scale_delta = 0.1;
    const ZOOM_MIN = 0.5, ZOOM_MAX = 2.5;

    const plus_elem = document.createElement("input");
    plus_elem.setAttribute("type", "button");
    plus_elem.setAttribute("value", "+");
    plus_elem.addEventListener("click", function() {
        zoom_factor = Math.min(ZOOM_MAX, zoom_factor + scale_delta);
        apply_viewport_layout();
    });

    const minus_elem = document.createElement("input");
    minus_elem.setAttribute("type", "button");
    minus_elem.setAttribute("value", "-");
    minus_elem.addEventListener("click", function() {
        zoom_factor = Math.max(ZOOM_MIN, zoom_factor - scale_delta);
        apply_viewport_layout();
    });

    btns_elem.appendChild(plus_elem);
    btns_elem.appendChild(minus_elem);
}

//
// Dark mode toggle (colour-only — no hardware background image)
//
if (DARK) {
    var dark_mode = DECK.dark_mode == undefined ? false : DECK.dark_mode;
    const dark_elem = document.createElement("input");
    dark_elem.setAttribute("type", "button");
    dark_elem.setAttribute("value", dark_mode ? "☀" : "☾");
    dark_elem.addEventListener("click", function() {
        dark_mode = !dark_mode;
        dark_elem.setAttribute("value", dark_mode ? "☀" : "☾");
        btns_elem.setAttribute("data-theme", dark_mode ? "dark" : "light");
        deck.set_background_image(null, dark_mode ? BACKGROUND_COLOR_ALT : null);
    });
    btns_elem.appendChild(dark_elem);

    if (dark_mode) {
        deck.set_background_image(null, BACKGROUND_COLOR_ALT);
    }
}

if (btns_elem.firstChild) {
    document.getElementById("app").appendChild(btns_elem);
}

window.addEventListener("resize", apply_viewport_layout);
if (window.visualViewport) {
    window.visualViewport.addEventListener("resize", apply_viewport_layout);
}

if (DEBUG) {
    var debug_elem = document.createElement("div");
    var code_elem  = document.createElement("pre");
    code_elem.textContent = JSON.stringify(DECK, null, 2);
    debug_elem.setAttribute("id", "debug");
    debug_elem.appendChild(code_elem);
    document.getElementsByTagName("body")[0].appendChild(debug_elem);
}

//
// WebSocket
//
const WS_CONNECT_RETRY_TIME = 5000;

if (DECK.ws_url == undefined) {
    console.error("No WebSocket address. Please start Cockpitdecks first.");
}

function sendCode(deckName, code) {
    try {
        if (ws) ws.send(JSON.stringify({"code": code, "deck": deckName}));
    } catch(e) { console.error("sendCode", e); }
}

function sendEvent(deckName, key, value, data) {
    try {
        if (ws) ws.send(JSON.stringify({"code": 0, "deck": deckName, "key": key, "event": value, "data": data}));
    } catch(e) { console.error("sendEvent", e); }
}

var ws;

function connect() {
    if (!DECK.ws_url) { console.error("No WebSocket URL — Cockpitdecks not running?"); return; }
    console.log("WebSocket trying every " + Math.round(WS_CONNECT_RETRY_TIME/1000) + " seconds...");
    var socket = new WebSocket(DECK.ws_url);

    socket.onopen = function(event) {
        console.log("WebSocket opened", DECK.ws_url);
        ws = socket;
        try { if (ws) sendCode(DECK.name, 1); } catch(e) { console.error("onopen", e); }
    };

    socket.onmessage = function(event) {
        let data;
        try { data = JSON.parse(event.data); } catch(e) {
            console.error("invalid websocket payload", e);
            return;
        }
        if (data.code == 0) {
            deck.set_key_image(data.key, data.image);
        } else if (data.code == 2) {
            deck.play_sound(data.sound, data.type);
        } else if (data.code == 8) {
            console.log("received init code, reloading");
            window.location.reload();
        } else if (data.code == 99) {
            // ping — no-op
        } else {
            console.log("unhandled code", data.code);
        }
    };

    socket.onclose = function() {
        ws = false;
        setTimeout(connect, WS_CONNECT_RETRY_TIME);
    };

    socket.onerror = function() {
        if (socket) socket.close();
    };
}

connect();
</script>
</body>
</html>
